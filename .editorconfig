root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{js,json,css,html}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.sql]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
