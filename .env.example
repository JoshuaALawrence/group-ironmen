# Host URL for the frontend (used for CORS and links)
HOST_URL=http://localhost:4000

# Optional image overrides if you publish your own frontend/backend images
FRONTEND_IMAGE=chrisleeeee/group-ironmen-tracker-frontend
BACKEND_IMAGE=chrisleeeee/group-ironmen-tracker-backend
IMAGE_TAG=latest

# PostgreSQL connection
PG_USER=postgres
PG_PASSWORD=change_me_in_production
PG_HOST=group-ironmen-tracker-db
PG_PORT=5432
PG_DB=groupironman

# Secret used for hashing authentication tokens (generate a strong random value)
BACKEND_SECRET=replace_with_a_64_char_random_hex_string

# hCaptcha secret key (leave empty to disable captcha verification)
HCAPTCHA_SECRET=
