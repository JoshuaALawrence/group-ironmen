{
  "name": "group-ironmen",
  "version": "1.0.0",
  "description": "Group Ironmen Tracker",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "axios": "^0.26.1",
    "chokidar": "^3.5.3",
    "clean-css": "^5.3.2",
    "compression": "^1.7.4",
    "concurrently": "^6.2.2",
    "esbuild": "^0.17.10",
    "eslint": "^7.32.0",
    "express": "^4.22.1",
    "express-winston": "^4.2.0",
    "glob": "^7.2.0",
    "husky": "^7.0.2",
    "jsdom": "^17.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^2.4.1",
    "terser": "^5.16.5",
    "vitest": "^3.1.1",
    "winston": "^3.3.3"
  },
  "scripts": {
    "bundle": "npm run clean && node build.js --prod",
    "clean": "node scripts/clean.js",
    "start": "concurrently \"npm run watch\" \"npm run serve -- --backend https://groupiron.men\"",
    "start:local-api": "concurrently \"npm run watch\" \"npm run serve -- --backend http://127.0.0.1:8081\"",
    "serve": "node scripts/server.js",
    "watch": "node build --watch",
    "lint": "eslint --ext .js src",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-component": "node scripts/generate-component.js",
    "prepare": "cd .. && husky install site/.husky",
    "precommit": "lint-staged && npm run lint"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "author": "Christopher Brown",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
